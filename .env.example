# Daze environment template
# Copy into your secret manager or local runtime environment. Never commit a filled .env file.

# -----------------------------------------------------------------------------
# TxLINE — server only. Never expose either credential with NEXT_PUBLIC_.
# -----------------------------------------------------------------------------
TXLINE_API_ORIGIN=https://txline-dev.txodds.com
TXLINE_API_TOKEN=
# Optional: normally fetched server-side on demand.
TXLINE_GUEST_JWT=
TXLINE_SERVICE_LEVEL_ID=1
TXLINE_PROGRAM_ID=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
TXLINE_TXL_MINT=4Zao8ocPhmMgq7PdsYWyxvqySMGx7xb9cMftPMkEokRG

# -----------------------------------------------------------------------------
# Application secrets — server only.
# -----------------------------------------------------------------------------
# 32+ random bytes. Required for wallet-session cookies.
AUTH_SESSION_SECRET=
# Required before production: durable database; never use the in-memory store.
DATABASE_URL=
# Optional until Telegram DMs are enabled. Keep server-side.
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# Solana devnet — public identifiers only; no private key or seed phrase here.
# -----------------------------------------------------------------------------
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_FANTASY_POOL_PROGRAM_ID=CYWN8hXCXREiUajoVEsxFoxP96fXkgV5MoTBexguAnSk
# Valueless, zero-decimal Token-2022 mint created for Daze devnet testing.
NEXT_PUBLIC_FANTASY_TEST_MINT=Dcr2NHLK1KBJGgDkktsJB4A218vtPcyukFHf1UEZrRcp
NEXT_PUBLIC_FANTASY_FIXTURE_ID=18175981
NEXT_PUBLIC_FANTASY_STAKE_AMOUNT=100

# Set these only for a currently open contest. Do not point users to a settled
# or expired contest. The current proof contests are historical test evidence.
NEXT_PUBLIC_FANTASY_STAKE_TIER=
NEXT_PUBLIC_FANTASY_CONTEST_ID=
NEXT_PUBLIC_FANTASY_LOCK_TS=

# -----------------------------------------------------------------------------
# Operator-only devnet scripts. Public addresses are okay; the keypair PATH is
# local-machine configuration, not a key value. Do not put keypair JSON here.
# -----------------------------------------------------------------------------
FANTASY_POOL_PROGRAM_ID=CYWN8hXCXREiUajoVEsxFoxP96fXkgV5MoTBexguAnSk
FANTASY_AUTHORITY=BHh9PezkfE7FZ24nDjvYnc2vdz8adXEDeBTbTH1fRPya
SOLANA_KEYPAIR_PATH=/Users/your-user/.config/solana/id.json
FANTASY_TEST_MINT=Dcr2NHLK1KBJGgDkktsJB4A218vtPcyukFHf1UEZrRcp
FANTASY_FIXTURE_ID=18175981
FANTASY_STAKE_TIER=
FANTASY_STAKE_AMOUNT=100
FANTASY_LOCK_TS=
FANTASY_WALLET=
FANTASY_TEAM_HASH=
FANTASY_CONTEST=
FANTASY_ENTRY=
FANTASY_AMOUNT=
FANTASY_PROOF=
FANTASY_PAYOUTS=
# Used only by the valueless test-token allocation script.
FANTASY_TOKEN_RECIPIENT=
FANTASY_TOKEN_AMOUNT=
