  "components": [
    {
      "name": "Primary Button",
      "kind": "button",
      "refersTo": "button-primary",
      "description": "The single decisive action on a task surface.",
      "html": "<button class=\"ds-btn-primary\">Confirm entry <span aria-hidden=\"true\">↗</span></button>",
      "css": ".ds-btn-primary{min-height:52px;display:inline-flex;align-items:center;gap:18px;padding:0 20px;border:0;border-radius:14px;background:var(--foreground,#351a12);color:var(--background,#f4f0e8);font:600 14px/20px Instrument Sans,sans-serif;cursor:pointer;transition:transform 160ms cubic-bezier(.32,.72,0,1),background 160ms cubic-bezier(.32,.72,0,1)}.ds-btn-primary:hover{transform:translateY(-2px)}.ds-btn-primary:active{transform:translateY(0)}.ds-btn-primary:focus-visible{outline:3px solid var(--focus,#2f6bff);outline-offset:3px}.ds-btn-primary:disabled{cursor:not-allowed;opacity:.55;transform:none}"
    },
    {
      "name": "Secondary Button",
      "kind": "button",
      "refersTo": "button-secondary",
      "description": "A familiar secondary action without decorative elevation.",
      "html": "<button class=\"ds-btn-secondary\">View details</button>",
      "css": ".ds-btn-secondary{min-height:44px;padding:0 14px;border:1px solid var(--border,#d8cfc3);border-radius:12px;background:transparent;color:var(--foreground,#351a12);font:600 14px/20px Instrument Sans,sans-serif;cursor:pointer;transition:background 160ms cubic-bezier(.32,.72,0,1)}.ds-btn-secondary:hover{background:var(--background-soft,#ece6dc)}.ds-btn-secondary:focus-visible{outline:3px solid var(--focus,#2f6bff);outline-offset:3px}.ds-btn-secondary:disabled{cursor:not-allowed;opacity:.55}"
    },
    {
      "name": "Status Chip",
      "kind": "chip",
      "refersTo": "status-positive",
      "description": "Explicit live or confirmed state with semantic surface and text.",
      "html": "<span class=\"ds-status\"><span aria-hidden=\"true\">●</span> Replay ready</span>",
      "css": ".ds-status{display:inline-flex;align-items:center;gap:6px;padding:5px 10px;border-radius:999px;background:var(--positive-surface,#ddf4e8);color:var(--positive,#28764c);font:700 12px/16px Instrument Sans,sans-serif;white-space:nowrap}.ds-status:focus-visible{outline:3px solid var(--focus,#2f6bff);outline-offset:3px}"
    },
    {
      "name": "Surface Card",
      "kind": "card",
      "refersTo": "card-surface",
      "description": "A flat gameplay container with solid surface and structural border.",
      "html": "<section class=\"ds-card\"><h3>Build your XI</h3><p>Choose 11 players from verified lineups.</p></section>",
      "css": ".ds-card{padding:24px;border:1px solid var(--border,#d8cfc3);border-radius:18px;background:var(--surface,#fff9f0);color:var(--foreground,#351a12);font-family:Instrument Sans,sans-serif}.ds-card h3{margin:0;font-size:22px;line-height:27px;letter-spacing:-.02em}.ds-card p{margin:8px 0 0;max-width:65ch;color:var(--muted,#766b63);font-size:14px;line-height:20px}.ds-card:focus-within{outline:3px solid var(--focus,#2f6bff);outline-offset:3px}"
    },
    {
      "name": "Select Field",
      "kind": "input",
      "refersTo": "field-select",
      "description": "Compact formation or position selection with a full touch target.",
      "html": "<label class=\"ds-field\"><span>Formation</span><select><option>4-3-3</option><option>4-4-2</option></select></label>",
      "css": ".ds-field{display:grid;gap:5px;color:var(--foreground,#351a12);font:700 13px/18px Instrument Sans,sans-serif}.ds-field select{min-height:44px;padding:0 10px;border:1px solid var(--border,#d8cfc3);border-radius:10px;background:var(--surface-raised,#fff);color:var(--foreground,#351a12);font:600 14px/20px Instrument Sans,sans-serif}.ds-field select:hover{background:var(--background-soft,#ece6dc)}.ds-field select:focus-visible{outline:3px solid var(--focus,#2f6bff);outline-offset:3px}.ds-field select:disabled{opacity:.55}"
    },
    {
      "name": "Product Navigation",
      "kind": "nav",
      "description": "Compact task navigation with muted routes and a clear wallet action.",
      "html": "<nav class=\"ds-nav\" aria-label=\"Preview navigation\"><div class=\"ds-nav-links\"><a href=\"#fixtures\">Fixtures</a><a href=\"#season\">Season</a></div><button>Connect wallet</button></nav>",
      "css": ".ds-nav{min-height:76px;display:flex;align-items:center;justify-content:space-between;gap:16px;padding:16px 24px;background:var(--background,#f4f0e8);font-family:Instrument Sans,sans-serif}.ds-nav-links{display:flex;gap:14px}.ds-nav a{min-height:44px;display:inline-flex;align-items:center;color:var(--muted,#766b63);font-size:14px;text-decoration:none}.ds-nav a:hover{color:var(--foreground,#351a12)}.ds-nav button{min-height:44px;padding:0 17px;border:0;border-radius:999px;background:var(--foreground,#351a12);color:var(--background,#f4f0e8);font-weight:600}.ds-nav a:focus-visible,.ds-nav button:focus-visible{outline:3px solid var(--focus,#2f6bff);outline-offset:3px}"
    },
    {
      "name": "Fixture Row",
      "kind": "custom",
